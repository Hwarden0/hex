{
  "name": "@hex-soc/hex",
  "version": "1.0.0",
  "description": "Splunk-native SOC simulation platform for security analyst training",
  "main": "cli/index.js",
  "bin": {
    "hex": "./bin/hex.js"
  },
  "scripts": {
    "dev": "node bin/hex.js",
    "lint": "eslint . --ext .js",
    "test": "jest --testEnvironment=node",
    "build:linux": "pkg . --targets node18-linux-x64 --output bin/hex",
    "build:macos": "pkg . --targets node18-macos-x64 --output bin/hex",
    "build:macos-arm": "pkg . --targets node18-macos-arm64 --output bin/hex",
    "build:windows": "pkg . --targets node18-win-x64 --output bin/hex.exe",
    "build": "npm run build:linux",
    "clean": "rm -f bin/hex bin/hex.exe"
  },
  "keywords": [
    "soc",
    "splunk",
    "security",
    "simulation",
    "training",
    "blue-team",
    "analyst"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "pkg": {
    "scripts": [
      "cli/**/*.js",
      "core/**/*.js",
      "engine/**/*.js",
      "scoring/**/*.js",
      "splunk/**/*.js",
      "cases/**/*.js",
      "submission/**/*.js",
      "validation/**/*.js",
      "leaderboard/**/*.js",
      "storage/**/*.js",
      "utils/**/*.js",
      "bin/hex.js"
    ],
    "assets": [
      "cases/case1/**/*",
      "cases/case2/**/*",
      "cases/case3/**/*",
      "cases/case4/**/*",
      "cases/case5/**/*",
      "cases/case6/**/*",
      "cases/case7/**/*",
      "cases/case8/**/*",
      "cases/case9/**/*",
      "cases/case10/**/*",
      "package.json"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1",
    "simple-git": "^3.21.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
